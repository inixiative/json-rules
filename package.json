{
  "name": "@inixiative/json-rules",
  "version": "1.2.0",
  "description": "TypeScript-first JSON rules engine with intuitive syntax and detailed error messages",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "bun run typecheck && bun run lint",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run check && bun run build"
  },
  "keywords": [
    "json",
    "rules",
    "engine",
    "validation",
    "typescript",
    "rules-engine",
    "business-rules"
  ],
  "author": "Aron Greenspan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inixiative/json-rules.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@electric-sql/pglite": "^0.3.15",
    "@types/bun": "^1.3.10",
    "@types/lodash": "^4.17.20",
    "@types/pg": "^8.16.0",
    "lefthook": "^2.1.2",
    "tsup": "^8.5.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "lodash": "^4.17.21",
    "pg": "^8.17.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  }
}
