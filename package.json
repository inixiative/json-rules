{
  "name": "@inixiative/json-rules",
  "version": "2.18.0",
  "description": "TypeScript-first JSON rules engine with intuitive syntax and detailed error messages",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check:catalog": "bun test test/operatorCatalog.integrity.test.ts",
    "check": "bun run typecheck && bun run lint && bun run test",
    "prepare": "lefthook install",
    "prepublishOnly": "bun run check && bun run build"
  },
  "keywords": [
    "json",
    "rules",
    "engine",
    "validation",
    "typescript",
    "rules-engine",
    "business-rules"
  ],
  "author": "Aron Greenspan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/inixiative/json-rules.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@electric-sql/pglite": "^0.3.15",
    "@inixiative/config": "^0.5.9",
    "@types/bun": "1.3.14",
    "@types/lodash-es": "^4.17.12",
    "lefthook": "2.1.9",
    "lodash-es": "^4.17.21",
    "tsup": "8.5.1",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "dayjs": "^1.11.13",
    "fastest-levenshtein": "^1.0.16"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "packageManager": "bun@1.3.14"
}
